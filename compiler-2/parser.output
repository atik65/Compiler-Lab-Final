    $end (0) 0
    error (256)
    IDENTIFIER <string> (258) 12 13 14 31
    INT_LITERAL <int_val> (259) 29
    FLOAT_LITERAL <float_val> (260) 30
    INT (261) 10
    FLOAT (262) 11
    IF (263) 15 16
    ELSE (264) 16
    WHILE (265) 17
    RETURN (266) 19
    PRINT (267) 18
    PLUS (268) 21
    MINUS (269) 22
    MULT (270) 27
    DIV (271) 28
    ASSIGN (272) 13 14
    EQ (273) 23
    NEQ (274)
